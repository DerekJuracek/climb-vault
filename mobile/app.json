{
  "expo": {
    "name": "Climb Vault",
    "slug": "climb-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.climbvault.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to record climbing sessions",
        "NSPhotoLibraryUsageDescription": "Used to select climbing videos from your library",
        "NSMicrophoneUsageDescription": "Used when recording climbing sessions"
      }
    },
    "android": {
      "package": "com.climbvault.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-video",
      ["expo-image-picker", { "photosPermission": "Allow Climb Vault to access your photos" }]
    ],
    "scheme": "climbvault"
  }
}
